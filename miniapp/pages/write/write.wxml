<view class="page write-page">
  <view class="topbar">
    <text class="back" bindtap="save">保存</text>
  </view>

  <view class="date serif">{{dateLabel}}</view>

  <textarea
    class="editor"
    placeholder="写点今天的事..."
    placeholder-class="placeholder"
    value="{{content}}"
    auto-focus
    bindinput="onInput"
  />

  <view wx:if="{{images.length > 0}}" class="image-row">
    <view wx:for="{{images}}" wx:key="*this" class="image-item">
      <image src="{{item.path}}" mode="aspectFill" />
      <text class="remove" data-index="{{index}}" bindtap="removeImage">×</text>
    </view>
  </view>

  <view class="type-toggle">
    <text class="faint">记录类型</text>
    <text class="type-value">{{recordTypes[typeIndex].label}}</text>
  </view>

  <view class="type-row">
    <text
      wx:for="{{recordTypes}}"
      wx:key="*this"
      class="type-pill {{typeIndex === index ? 'active' : ''}}"
      data-index="{{index}}"
      bindtap="chooseType"
    >{{item.label}}</text>
  </view>

  <view class="mood-row">
    <text
      wx:for="{{moods}}"
      wx:key="id"
      class="mood {{moodId === item.id ? 'mood-active' : ''}}"
      data-mood="{{item}}"
      bindtap="chooseMood"
    >{{item.emoji}}</text>
  </view>

  <view wx:if="{{savingMessage}}" class="saving">{{savingMessage}}</view>

  <view class="bottom-tools">
    <view class="tool" bindtap="chooseImage">📷</view>
    <view class="tool selected">{{moodEmoji || '😊'}}</view>
  </view>
</view>
