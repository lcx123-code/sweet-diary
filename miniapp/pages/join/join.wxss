.back {
  margin-bottom: 60rpx;
  color: #7C756D;
  font-size: 32rpx;
}

.title {
  margin-bottom: 24rpx;
  font-size: 76rpx;
  font-weight: 700;
}

.subtitle {
  margin-bottom: 56rpx;
  color: #7C756D;
  font-size: 32rpx;
  line-height: 1.6;
}

.code-box {
  margin-bottom: 40rpx;
  padding: 28rpx 24rpx;
  border: 1rpx solid #E8E4DE;
  border-radius: 28rpx;
  background: #FFFFFF;
}

.code-box input {
  color: #A8B8A5;
  text-align: center;
  font-size: 48rpx;
  font-weight: 700;
  letter-spacing: 12rpx;
}

.placeholder {
  color: #A39D96;
}
