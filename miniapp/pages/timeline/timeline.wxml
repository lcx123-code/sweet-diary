<view class="page">
  <view class="title serif">回忆</view>
  <view class="subtitle">你们一起写下的日子</view>

  <view wx:if="{{loading}}" class="empty">正在整理回忆...</view>
  <view wx:elif="{{years.length === 0}}" class="empty">还没有记录，从一句话开始也很好。</view>

  <block wx:else wx:for="{{years}}" wx:key="year">
    <view class="year serif">{{item.year}}</view>
    <block wx:for="{{item.months}}" wx:for-item="month" wx:key="month">
      <view class="month serif">{{month.month}}</view>
      <block wx:for="{{month.entries}}" wx:for-item="entry" wx:key="id">
        <view class="row {{entry.type !== '普通记录' ? 'milestone' : ''}}" data-id="{{entry.id}}" bindtap="goEntry">
          <view class="dot {{entry.type !== '普通记录' ? 'dot-on' : ''}}"></view>
          <view class="day serif">{{entry.day}}</view>
          <view class="text">
            <view class="preview">{{entry.content}}</view>
            <view wx:if="{{entry.type !== '普通记录'}}" class="tag">{{entry.type}}</view>
          </view>
          <image wx:if="{{entry.images.length > 0}}" src="{{entry.images[0]}}" mode="aspectFill" />
          <view wx:if="{{entry.mood}}" class="mood">{{entry.mood}}</view>
          <view class="author">{{entry.author[0]}}</view>
        </view>
      </block>
      <view class="divider"></view>
    </block>
  </block>
</view>
