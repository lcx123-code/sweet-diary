page {
  min-height: 100%;
  background: #FAF8F5;
  color: #2B2B2B;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 56rpx 40rpx 96rpx;
  background: #FAF8F5;
}

.serif {
  font-family: "Songti SC", "Noto Serif SC", serif;
}

.muted {
  color: #7C756D;
}

.faint {
  color: #A39D96;
}

.hairline {
  height: 1rpx;
  background: #E8E4DE;
}

.primary-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  padding: 0 44rpx;
  border-radius: 999rpx;
  background: #A8B8A5;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
}

.outline-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  padding: 0 44rpx;
  border: 1rpx solid #A8B8A5;
  border-radius: 999rpx;
  color: #A8B8A5;
  font-size: 28rpx;
  font-weight: 600;
}

.section-label {
  margin-bottom: 12rpx;
  color: #A39D96;
  font-size: 24rpx;
}

.body-text {
  color: #2B2B2B;
  font-size: 34rpx;
  line-height: 1.7;
}

.caption {
  color: #7C756D;
  font-size: 26rpx;
}

.collage {
  display: grid;
  gap: 12rpx;
  overflow: hidden;
}

.collage image {
  width: 100%;
  height: 100%;
  border-radius: 28rpx;
  object-fit: cover;
}

.collage-1 {
  height: 430rpx;
}

.collage-2 {
  grid-template-columns: 1fr 1fr;
  height: 320rpx;
}

.collage-3 {
  grid-template-columns: 2fr 1fr;
  grid-template-rows: 1fr 1fr;
  height: 430rpx;
}

.collage-3 image:first-child {
  grid-row: 1 / 3;
}

.collage-4 {
  grid-template-columns: 1fr 1fr;
  height: 430rpx;
}

.pill {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: #E5EDE2;
  color: #A8B8A5;
  font-size: 24rpx;
  font-weight: 600;
}
